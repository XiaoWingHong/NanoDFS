{
  "name": "nanodfs",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace server\" \"npm:dev --workspace web\"",
    "build": "npm run build --workspace web && npm run build --workspace server",
    "start": "npm run start --workspace server",
    "test": "npm run test --workspace server",
    "smoke": "node scripts/smoke-e2e.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
